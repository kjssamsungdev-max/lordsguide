# LordsGuide — Environment Variables
# Copy to .env.local for local development
# Set in Cloudflare Dashboard > Pages > Settings > Environment variables for production

# API Proxy URL (Cloudflare Worker that forwards to Anthropic API with server-side key)
# REQUIRED for production — never expose API keys client-side
VITE_ANTHROPIC_PROXY_URL=https://lg-api-proxy.your-account.workers.dev

# Optional: Analytics
# VITE_PLAUSIBLE_DOMAIN=lordsguide.com

# Optional: Error tracking
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
