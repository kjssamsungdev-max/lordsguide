{
  "manifest_version": 3,
  "name": "LordsGuide — Daily Verse",
  "version": "1.0.0",
  "description": "Start every tab with Scripture. A daily Bible verse on your new tab page, powered by LordsGuide.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "newtab.html",
    "default_icon": "icons/icon48.png"
  }
}
